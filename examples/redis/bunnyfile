#syntax=harbor.nbfc.io/nubificus/bunny:latest
version: v0.1
platforms:
  framework: unikraft
  monitor: qemu
  architecture: x86_64
rootfs:
  from: scratch
  type: initrd
  include:
  - redis.conf:/conf/redis.conf
kernel:
  from: local
  path: redis-qemu-x86_64
cmdline: "redis-server /conf/redis.conf"
